# Local sqlite fallback
AXISX_DB_PATH=./axisx.db

# Optional Postgres fallback (disabled when MONGODB_URI is set)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Primary persistence (MongoDB Atlas or Render external Mongo)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<options>
MONGODB_DB_NAME=axisx

# Comma-separated allowed origins for frontend
CORS_ORIGINS=https://axisx-frontend.onrender.com,http://localhost:5173,http://127.0.0.1:5173
